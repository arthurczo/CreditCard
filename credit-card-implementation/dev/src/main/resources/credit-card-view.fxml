<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.jala.university.presentation.controller.CreditCardViewController"
            stylesheets="@credit-card-view.css">
   <top>
      <HBox alignment="CENTER_RIGHT" spacing="10">
         <padding>
            <Insets top="15" right="15" bottom="15" left="15"/>
         </padding>
         <Label styleClass="title" text="Área de Cartões" HBox.hgrow="ALWAYS" />
         <Button fx:id="exitButton" styleClass="back-button" text="Sair"/>
      </HBox>
   </top>

   <center>
      <VBox spacing="20" alignment="CENTER">
         <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
         </padding>

         <HBox fx:id="cardInfoContainer" spacing="20">
            <!-- Credit Card -->
            <VBox HBox.hgrow="ALWAYS" styleClass="credit-card" spacing="10" >
               <padding>
                  <Insets top="20" right="20" bottom="20" left="20"/>
               </padding>

               <Region VBox.vgrow="ALWAYS"/>

               <Label fx:id="cardHolderNameLabel" styleClass="card-text" text="Nome do titular"/>
               <Label fx:id="cardNumberLabel" styleClass="card-text" text="Número do cartão"/>
               <Label fx:id="cardCvvLabel" styleClass="card-text" text="Número do CVV"/>
               <Label fx:id="cardStatusLabel" styleClass="card-text" text="Status"/>
            </VBox>

            <VBox styleClass="invoice-info" spacing="15">
               <padding>
                  <Insets top="20" right="20" bottom="20" left="20"/>
               </padding>
               <HBox>
                  <Label text="Fatura: " styleClass="invoice-label"/>
                  <Label fx:id="invoiceMonthLabel" styleClass="invoice-value" text="Abril"/>
               </HBox>
               <HBox>
                  <Label text="Valor: " styleClass="invoice-label"/>
                  <Label fx:id="invoiceAmountLabel" styleClass="invoice-value" text="R$ 1589,90"/>
               </HBox>
               <Button fx:id="payButton" text="Pagar" styleClass="action-button"
                       maxWidth="Infinity"/>
               <Button fx:id="detailsButton" text="Detalhes" styleClass="action-button"
                       maxWidth="Infinity"/>
            </VBox>
         </HBox>

         <VBox fx:id="noCardContainer" spacing="20" alignment="CENTER" styleClass="no-card-container">
            <padding>
               <Insets top="40" right="20" bottom="40" left="20"/>
            </padding>
            <Label text="Você ainda não tem um cartão de crédito" styleClass="no-card-message"/>
            <Button fx:id="requestCardButton" text="Solicitar Cartão"
                    styleClass="request-card-button" onAction="#handleRequestCardButton"/>
         </VBox>

         <!-- CARD OPTIONS BUTTONS -->

         <GridPane hgap="10" vgap="10">
            <columnConstraints>
               <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
               <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            </columnConstraints>

            <rowConstraints>
               <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
               <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>

            <Button fx:id="transactionsButton" text="Transações" styleClass="function-button"
                    maxWidth="Infinity"
                    GridPane.columnIndex="0" GridPane.rowIndex="0"
                    onAction="#handleTransactionsButton"
            />

            <Button fx:id="invoicesButton" text="Faturas" styleClass="function-button"
                    maxWidth="Infinity"
                    GridPane.columnIndex="1" GridPane.rowIndex="0"
                    onAction="#handleInvoicesButton"/>

            <Button fx:id="blockButton" text="Bloqueio" styleClass="function-button"
                    maxWidth="Infinity"
                    GridPane.columnIndex="0" GridPane.rowIndex="1"
                    onAction="#handleBlockButton"
            />

            <Button fx:id="increaseLimitButton" text="Aumento de limite" styleClass="function-button"
                    maxWidth="Infinity"
                    GridPane.columnIndex="1" GridPane.rowIndex="1"
                    onAction="#handleIncreaseLimitButton"
            />
         </GridPane>
      </VBox>
   </center>
</BorderPane>