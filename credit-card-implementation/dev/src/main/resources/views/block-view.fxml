<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<?import org.kordamp.ikonli.javafx.FontIcon?>
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="arthurczo.dev.presentation.controller.BlockCardViewController"
      alignment="CENTER"
      spacing="10"
      style="-fx-padding: 20;"
      stylesheets="@/style/style.css">

    <VBox alignment="CENTER" spacing="20">
        <HBox alignment="CENTER" spacing="5">
            <FontIcon fx:id="statusIcon" iconLiteral="fas-check-circle" iconSize="16" styleClass="status-active-icon"/>
            <Label fx:id="statusLabel" text="Ativo" styleClass="status-active-label"/>
        </HBox>

        <VBox alignment="CENTER" spacing="10">
            <Button fx:id="blockButton" text="Bloquear Cartão" onAction="#onBlockCard" styleClass="main-button"/>
            <Button fx:id="unblockButton" text="Desbloquear Cartão" onAction="#onUnblockCard" styleClass="main-button"/>
            <Button fx:id="simulateButton" text="Simular Transação" onAction="#onSimulateTransaction" styleClass="main-button"/>
        </VBox>
    </VBox>

</VBox>
